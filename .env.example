# IAAA · V1 · Environment Variables
# Copy to .env and fill values — never commit .env to git

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=iaaa
POSTGRES_USER=iaaa_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql+asyncpg://iaaa_user:CHANGE_ME_STRONG_PASSWORD@postgres:5432/iaaa

# ── Backend ───────────────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_64_CHAR_RANDOM_STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── AI Provider (one active at a time) ───────────────────────────────────────
# Set AI_PROVIDER to "openai" | "anthropic" | "openrouter"
AI_PROVIDER=openai
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter — inference key (backend only, never frontend)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o
# OpenRouter management key — admin cockpit only, NOT used for inference
OPENROUTER_MGMT_KEY=sk-or-mgmt-...

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_CLARITY=price_...
STRIPE_PRICE_ID_SIS=price_...

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://iaaa.app/api

# ── Domain ────────────────────────────────────────────────────────────────────
DOMAIN=iaaa.app
