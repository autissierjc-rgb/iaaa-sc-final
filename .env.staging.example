# IAAA · Staging Environment
# Copy to .env on the OVH staging VPS — never commit this file
#
# ── Variable categories ───────────────────────────────────────────────────────
#
# FRONTEND BUILD ARGS (baked into Next.js bundle at docker build time)
#   NEXT_PUBLIC_APP_URL
#   NEXT_PUBLIC_API_URL
#
# FRONTEND RUNTIME (injected at container start — server-side only)
#   INTERNAL_API_BASE_URL  ← set in docker-compose.yml, not here
#
# BACKEND RUNTIME (loaded via env_file: .env)
#   everything below
#
# ─────────────────────────────────────────────────────────────────────────────

# ── App identity ──────────────────────────────────────────────────────────────
APP_ENV=staging
DOMAIN=staging.iaaa.app

# ── Frontend — build args (baked at docker build) ────────────────────────────
NEXT_PUBLIC_APP_URL=https://staging.iaaa.app
NEXT_PUBLIC_API_URL=https://staging.iaaa.app/api

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=iaaa_staging
POSTGRES_USER=iaaa_staging_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_RANDOM_PASSWORD
# Host must be "postgres" (Docker Compose service name) — never "localhost"
DATABASE_URL=postgresql+asyncpg://iaaa_staging_user:CHANGE_ME_STRONG_RANDOM_PASSWORD@postgres:5432/iaaa_staging

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_64_CHAR_RANDOM_HEX_STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── AI Provider ───────────────────────────────────────────────────────────────
# Use OpenRouter in staging — cheaper model, same code path
AI_PROVIDER=openrouter
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini
OPENROUTER_MGMT_KEY=sk-or-mgmt-...

# ── Stripe — test keys only ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_CLARITY=price_test_...
STRIPE_PRICE_ID_SIS=price_test_...
